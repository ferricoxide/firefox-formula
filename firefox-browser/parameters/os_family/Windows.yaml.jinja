# -*- coding: utf-8 -*-
# vim: ft=yaml
#
# Set values specific to:
#   salt['config.get']('os_family') == Windows.
#
# You just need to add the key:values for this `os_family` that differ
# from `defaults.yaml` + `<osarch>.yaml`.
#
# If you do not need to provide defaults via the `os_family` config,
# you can remove this file or provide at least an empty dict, e.g.
# values: {}
---
values:
  pkg:
{%- if salt.grains.get('cpuarch') == 'AMD64' %}
    install_uri: 'https://download.mozilla.org/?product=firefox-latest-ssl&os=win64&lang=en-US'
    uninstaller: 'C:/Program Files/Mozilla Firefox/uninstall/helper.exe'
{%- else %}
    install_uri: 'https://download.mozilla.org/?product=firefox-latest-ssl&os=win32&lang=en-US'
    uninstaller: 'C:/Program Files (x86)/Mozilla Firefox/uninstall/helper.exe'
{%- endif %}
...
